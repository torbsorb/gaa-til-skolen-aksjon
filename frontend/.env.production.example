# Production frontend API base.
# Use full URL if backend runs on another host.
# Example:
# VITE_API_BASE_URL=https://api.example.com

# If omitted, frontend defaults to same-origin /api.
# VITE_API_BASE_URL=

# Local dev with npm run dev: create .env.local (gitignored) to use a remote API, e.g.:
# VITE_API_BASE_URL=https://your-service.onrender.com
